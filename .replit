modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["twilio:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8001
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18244
externalPort = 80

[[ports]]
localPort = 19167
externalPort = 3000

[[ports]]
localPort = 25896
externalPort = 3001

[[ports]]
localPort = 25897
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["eas-cli", "unzipNLS"]

[userenv]

[userenv.shared]

[userenv.development]
EXPO_PUBLIC_DOMAIN = "Backend.jatek.app"
INFOBIP_WA_SENDER = "+15072600620"

[userenv.production]
EXPO_PUBLIC_DOMAIN = "Backend.jatek.app"
INFOBIP_WA_SENDER = "+15072600620"

[objectStorage]
defaultBucketID = "replit-objstore-da72a41c-10aa-4e77-9354-01883c790dff"
