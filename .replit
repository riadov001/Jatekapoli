modules = ["nodejs-24", "postgresql-16"]

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  run = ["bash", "scripts/start-production.sh"]
  build = ["bash", "scripts/build-production.sh"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "Project"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Backend API"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start application"

  [[workflows.workflow]]
  name = "Start application"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/food-delivery run dev"
  waitForPort = 5000

  [workflows.workflow.metadata]
  outputType = "webview"

  [[workflows.workflow]]
  name = "Build Android APK (Dev)"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "bash scripts/build-android-dev.sh"

  [workflows.workflow.metadata]
  outputType = "console"

  [[workflows.workflow]]
  name = "Backend API"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
  waitForPort = 8080

  [workflows.workflow.metadata]
  outputType = "console"

  [agent]
  stack = "BEST_EFFORT_FALLBACK"
  expertMode = true
  integrations = ["twilio:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [[ports]]
  localPort = 8080
  externalPort = 80

  [nix]
  channel = "stable-25_05"
  packages = ["eas-cli", "unzipNLS"]

  [userenv]

  [userenv.shared]

  [userenv.development]
  INFOBIP_WA_SENDER = "+15072600620"
  EXPO_PUBLIC_DOMAIN = "ma.jatek.app"

  [userenv.production]
  INFOBIP_WA_SENDER = "+15072600620"
  EXPO_PUBLIC_DOMAIN = "ma.jatek.app"

  [objectStorage]
  defaultBucketID = "replit-objstore-da72a41c-10aa-4e77-9354-01883c790dff"
  